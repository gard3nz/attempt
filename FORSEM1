    // -----------------------------------------------------------------
    /// @brief Найти объект по имени в списке m_items
    ///
    /// Проходит по вектору m_items и ищет элемент с заданным именем.
    /// Возвращает итератор на найденный элемент.
    /// Если элемент не найден — возвращает m_items.end()
    ///
    /// Использование:
    ///   auto it = findItem("МойКуб");
    ///   if (it == m_items.end()) {
    ///       throw std::runtime_error("Объект не найден: МойКуб");
