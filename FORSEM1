    ///   TopoDS_Shape shape = it->shape; // получить форму
    ///
    // -----------------------------------------------------------------
    std::vector<GeomItem>::iterator findItem(const std::string& name) {
        return std::find_if(m_items.begin(), m_items.end(),
            [&name](const GeomItem& item) {
                return item.name == name;
            });
