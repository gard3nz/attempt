    //      (полная сфера: phi от 0 до 360, theta от 0 до 180)
    //   3. Создать GeomItem и добавить в m_items
    // -----------------------------------------------------------------
    void executeCreateSphere(const std::string& params) {
        std::vector<std::string> tokens = CommandUtils::splitBySpace(params);
        if (tokens.size() < 10)
            return;
        double cx, cy, cz, r;
