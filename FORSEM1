    // и должен вызвать соответствующий обработчик.
    //
    // Подсказка: используйте цепочку if / else if для сопоставления
    // имени команды с нужным методом-обработчиком.
    // =================================================================
    void dispatchCommand(const std::string& cmdName,
                         const std::string& params)
    {
        if (cmdName == "Geom.CreateCube") {
            executeCreateCube(params);
        }
        else if (cmdName == "Geom.CreateSphere") {
            executeCreateSphere(params);
        }
        else if (cmdName == "Geom.CreateCylinder") {
            executeCreateCylinder(params);
        }
    }

