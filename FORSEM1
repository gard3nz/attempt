        TopoDS_Shape shape = m_core.CreateSphere(cx, cy, cz, r, 0, 360, 0, 180);
        GeomItem item;
        item.shape = shape;
        item.name = tokens[0];
        item.material = "Default";
        m_items.push_back(item);
    }

    // -----------------------------------------------------------------
