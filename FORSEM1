    // -----------------------------------------------------------------
    void executeCreateCylinder(const std::string& params) {
        std::vector<std::string> tokens = CommandUtils::splitBySpace(params);
        if (tokens.size() < 11)
            return;
        double cx, cy, cz, r, height;
        r = CommandUtils::toDouble(tokens[2]);
        cx = CommandUtils::toDouble(tokens[3]);
        cy = CommandUtils::toDouble(tokens[4]);
        cz = CommandUtils::toDouble(tokens[5]);
        height = CommandUtils::toDouble(tokens[6]);
        
        Orientation orientation = stringToOrientation(tokens[1]);
        TopoDS_Shape shape = m_core.CreateCylinders(orientation, r, r, cx, cy, cz, height, 0, 0);
        GeomItem item;
        item.shape = shape;
        item.name = tokens[0];
        item.material = "Default";
        m_items.push_back(item);
    }

