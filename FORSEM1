/// @brief Элемент геометрической сцены
///
/// Содержит:
/// - name     — уникальное имя объекта (задаётся пользователем в команде)
/// - shape    — геометрическая форма (результат работы GeomCore)
/// - material — название материала (для данной работы — просто строка)
///
/// Пример: после команды "Geom.CreateCube МойКуб 0 0 0 10 10 10"
///   name     = "МойКуб"
///   shape    = результат GeomCore::CreateCube(0, 0, 0, 10, 10, 10)
///   material = "Default"
struct GeomItem {
    std::string    name;        ///< Имя объекта (уникальный идентификатор)
    TopoDS_Shape   shape;       ///< Геометрическая форма (OCCT)
    std::string    material;    ///< Название материала
};

class GeomEditor {
public:
    GeomEditor() = default;
    ~GeomEditor() = default;

    // =================================================================
    /// @brief Главный метод: принимает набор текстовых команд
    ///
    /// Логика работы:
    ///   1. Разбить вход на строки
    ///   2. Для каждой строки:
    ///      a. Пропустить комментарии и пустые строки
    ///      b. Разобрать строку на имя команды и параметры
    ///      c. Вызвать dispatchCommand
    ///   3. Все созданные объекты сохраняются в m_items
    ///
    /// @param commands — вектор строк, каждая строка — одна команда
    // =================================================================
    void processCommands(const std::vector<std::string>& commands) {
        m_items.clear();

        for (const auto& line : commands) {
            // Пропускаем пустые строки и комментарии
            if (CommandUtils::isComment(line)) continue;

            try {
                auto parsed = CommandUtils::parseLine(line);
                dispatchCommand(parsed.command, parsed.params);
            }
            catch (const std::exception& e) {
                std::cerr << "[StudentAdapter Error] Команда '"
                          << line << "' завершилась ошибкой: "
                          << e.what() << "\n";
            }
        }
    }

    // =================================================================
    /// @brief Получить результат — все построенные объекты
    /// @return Вектор GeomItem (имя + форма + материал)
    // =================================================================
    std::vector<GeomItem> getResult() const {
        return m_items;
    }

