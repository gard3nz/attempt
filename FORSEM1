    // Пример: "МойКуб 0 0 0 10 10 10"
    //
    // Что нужно сделать:
    //   1. Распарсить строку params — извлечь имя и 6 чисел
    //   2. Вызвать m_core.CreateCube(x, y, z, x1, y1, d1)
    //   3. Создать GeomItem с именем, формой и материалом "Default"
    //   4. Добавить его в m_items
    //
    // Подсказка: используйте std::istringstream для парсинга
    // Или используйте методы CommandUtils::
    // -----------------------------------------------------------------
    void executeCreateCube(const std::string& params) {
        std::vector<std::string> tokens = CommandUtils::splitBySpace(params);
        if (tokens.size() < 8)
            return;
        double x, y, z, x1, y1, z1;
        x = CommandUtils::toDouble(tokens[1]);
        y = CommandUtils::toDouble(tokens[2]);
        z= CommandUtils::toDouble(tokens[3]);
        x1 = CommandUtils::toDouble(tokens[4]);
        y1 = CommandUtils::toDouble(tokens[5]);
        z1 = CommandUtils::toDouble(tokens[6]);
        TopoDS_Shape shape = m_core.CreateCube(x, y, z, x1, y1, z1);
        GeomItem item;
        item.shape = shape;
        item.name = tokens[0];
        item.material = "Default";
        m_items.push_back(item);

    }

